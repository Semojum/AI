# ── 서버 설정 ────────────────────────────────────────────────────
GRPC_PORT=50051
REST_PORT=8080
APP_ENV=production           # debug 시 각 PART 완료 후 Pydantic JSON 덤프 저장

# ── 타임아웃 / 임계값 ─────────────────────────────────────────────
PAGE_TIMEOUT_SECONDS=180
OCR_CONFIDENCE_THRESHOLD=0.90
MAX_GRPC_MESSAGE_MB=20

# ── HCXT 추론 백엔드 ─────────────────────────────────────────────
# transformers(기본): 인프로세스 bitsandbytes 4bit. vllm: 별도 vLLM 서버로 오프로드(고속).
# vllm 쓰려면 AWQ 양자화 모델을 self-host 권장(bnb는 엔진 바꿔도 이득 없음, 실측 확인).
#   서버 실행 예: vllm serve /models/hcxt-awq --served-model-name hcxt --quantization awq \
#                 --port 8100 --max-model-len 4096 --gpu-memory-utilization 0.6
# HCXT_BACKEND=vllm
# HCXT_VLLM_URL=http://127.0.0.1:8100/v1
# HCXT_VLLM_MODEL=hcxt
# HCXT_VLLM_SERVE_CMD=      # 비우면 외부 서버 사용, 채우면 서버 기동 시 이 명령으로 자동 기동

# ── GPU 디바이스 배치 ─────────────────────────────────────────────
# GCP L4 × 2 기본: QWEN=0, HCXT=1
# 단일 GPU(WSL 로컬 RTX 4090 등): 두 값 모두 0
QWEN_GPU_DEVICE=0
HCXT_GPU_DEVICE=1

# ── 모델 경로 (단계 2+ 설정) ──────────────────────────────────────
# GCP L4 (절대경로 배포 기준)
# QWEN3_VL_MODEL_PATH=/models/qwen3-vl-8b-awq
# HCXT_MODEL_PATH=/models/hyperclovax-seed-think-14b
# DOCLAYOUT_YOLO_PATH=/models/doclayout-yolo-v2
# DOCLING_TABLEFORMER_PATH=/models/docling-tableformer

# WSL/로컬 (상대경로, code/AI 기준 — code/AI/models/ 하위)
QWEN3_VL_MODEL_PATH=models/qwen3-vl-8b-awq
HCXT_MODEL_PATH=models/hcxt
DOCLAYOUT_YOLO_PATH=models/doclayout-yolo-v2
DOCLING_TABLEFORMER_PATH=models/docling-tableformer

# ── 외부 서비스 (단계 3+ 설정) ────────────────────────────────────
FORMULANET_SERVICE_ADDR=localhost:50052
CHROMADB_URL=http://localhost:8001
TIMESCALEDB_URL=postgresql://user:pass@localhost:5432/semojum_metrics

# ── TLS ──────────────────────────────────────────────────────────
TLS_ENABLED=true
TLS_CERT_PATH=/etc/ssl/semojum/server.crt
TLS_KEY_PATH=/etc/ssl/semojum/server.key

# ── API Fallback (단계 3+ 설정) ───────────────────────────────────
OPENAI_API_KEY=sk-...
